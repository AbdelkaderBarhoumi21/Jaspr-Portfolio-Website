# Files and directories created by pub.
**/doc/api/
.dart_tool/
.packages

# Conventional directory for build output.
/build/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Jaspr — generated files
# These are produced by `jaspr_builder` (build_runner) and should not be tracked.
lib/**/*.options.dart
lib/**/*.g.dart
lib/**/*.freezed.dart

# Jaspr build output
/build/jaspr/

# Stray CLI artifact (zero-byte file created in some environments)
/jaspr

# OS / editor noise
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Claude Code local settings (per-machine, not for the repo)
.claude/settings.local.json
